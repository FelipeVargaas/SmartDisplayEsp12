<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
        x:Class="SmartDisplayPcAgent.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="500"
        Height="680"
        Title="Smart Display PC Agent">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="24"
          RowSpacing="18">

        <TextBlock Grid.Row="0"
                   Text="Smart Display PC Agent"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1"
                    Spacing="14"
                    VerticalAlignment="Center">

            <TextBlock Text="{Binding CpuUsage, StringFormat='CPU  {0:0}%'}"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding CpuUsage}"
                         Height="14"/>

            <TextBlock Text="{Binding RamUsage, StringFormat='RAM  {0:0}%'}"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding RamUsage}"
                         Height="14"/>

            <TextBlock Text="{Binding GpuUsage, StringFormat='GPU  {0:0}%'}"
                       FontSize="28"
                       FontWeight="SemiBold"/>

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding GpuUsage}"
                         Height="14"/>

            <TextBlock Text="{Binding DiskDisplayText}"
                        FontSize="28"
                        FontWeight="SemiBold"/>

            <ProgressBar Minimum="0"
                            Maximum="100"
                            Value="{Binding DiskUsage}"
                            Height="14"/>

            <TextBlock Text="Discos detectados"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Margin="0,8,0,0"/>

            <Border BorderBrush="#333333"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    Background="#151515">

                <TextBlock Text="{Binding DisksText}"
                            FontSize="12"
                            TextWrapping="Wrap"/>
            </Border>

            <Border Height="1"
                    Background="#333333"
                    Margin="0,8,0,4"/>

            <TextBlock Text="Display ESP8266"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <TextBox Watermark="IP do display"
                     Text="{Binding DisplayIp, Mode=TwoWay}"/>

            <CheckBox Content="Enviar dados para o display"
                      IsChecked="{Binding SendToDisplayEnabled}"/>

            <Button Content="Enviar teste agora"
                    Command="{Binding SendTestCommand}"
                    HorizontalAlignment="Stretch"/>

            <TextBlock Text="{Binding DisplayStatusText}"
                       TextWrapping="Wrap"
                       Opacity="0.75"/>

        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   HorizontalAlignment="Center"
                   Opacity="0.7"/>
    </Grid>
</Window>