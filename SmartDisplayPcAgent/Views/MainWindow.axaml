<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
        xmlns:views="using:SmartDisplayPcAgent.Views"
        x:Class="SmartDisplayPcAgent.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="620"
        Title="TinyDash Agent"
        Background="#070B10">


    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#8FA3B8"/>
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style Selector="TextBlock.metric-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.metric-value">
            <Setter Property="Foreground" Value="#168BFF"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.accent">
            <Setter Property="Foreground" Value="#D46F2A"/>
        </Style>

        <Style Selector="TextBlock.ok">
            <Setter Property="Foreground" Value="#35C46B"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#101820"/>
            <Setter Property="BorderBrush" Value="#1E2A36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Foreground" Value="#168BFF"/>
            <Setter Property="Background" Value="#1E2A36"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>



        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.accent-button">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="BorderBrush" Value="#D46F2A"/>
        </Style>

        <Style Selector="TabControl">
            <Setter Property="Background" Value="#070B10"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="22"
          RowSpacing="14">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="18">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="18">
                <Border Width="4"
                        Height="48"
                        CornerRadius="2"
                        Background="#D46F2A"/>

                <StackPanel Spacing="2"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="TinyDash"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Agent"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#D46F2A"/>
                    </StackPanel>

                    <TextBlock Text="Display telemetry service"
                               FontSize="14"
                               Classes="muted"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="card"
                    Padding="16,10"
                    MinWidth="260">
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8">
                    <Ellipse Grid.Row="0"
                             Grid.Column="0"
                             Width="9"
                             Height="9"
                             Fill="#35C46B"
                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding Dashboard.EspHeaderStatusText}"
                               Classes="ok"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Dashboard.DeviceHeaderText}"
                               Classes="muted"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
                <views:DashboardView DataContext="{Binding Dashboard}"/>
            </TabItem>

            <TabItem Header="Device">
                <views:DeviceView DataContext="{Binding Device}"/>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,*"
              MinHeight="28">
            <TextBlock Grid.Column="0"
                       Text="{Binding Dashboard.StatusText}"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="Send interval: 1.0 s"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="Version: 1.0.0"
                       Classes="muted"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
