<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="using:SmartDisplayPcAgent.Resources"
             xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
             x:Class="SmartDisplayPcAgent.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Styles>
        <Style Selector="Slider.animation-slider">
            <Setter Property="Foreground" Value="#FF7A1A"/>
            <Setter Property="Background" Value="#1E2A36"/>
        </Style>

        <Style Selector="Slider.animation-slider:pointerover">
            <Setter Property="Foreground" Value="#FF8A2A"/>
        </Style>

        <Style Selector="Slider.animation-slider /template/ Thumb">
            <Setter Property="Background" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#FF7A1A"/>
        </Style>

        <Style Selector="Slider.animation-slider /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#FF8A2A"/>
            <Setter Property="BorderBrush" Value="#FF8A2A"/>
        </Style>

        <Style Selector="Slider.animation-slider /template/ Thumb:pressed">
            <Setter Property="Background" Value="#E96500"/>
            <Setter Property="BorderBrush" Value="#E96500"/>
        </Style>
    </UserControl.Styles>

    <Grid>
    <Grid ColumnDefinitions="1.05*,1*"
          RowDefinitions="1.15*,0.85*"
          ColumnSpacing="16"
          RowSpacing="16"
          Margin="0,12,0,0">

        <Border Grid.Row="0"
                Grid.Column="0"
                Classes="card">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="14">
                <TextBlock Text="{x:Static res:Strings.DashboardLocalMetrics}"
                           Classes="section-title"/>

                <Grid Grid.Row="1"
                      RowDefinitions="*,*,*,*"
                      RowSpacing="10">
                    <Grid Grid.Row="0"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="7">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="CPU" Classes="metric-title"/>
                            <TextBlock Grid.Column="1" Text="{Binding CpuUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                        </Grid>
                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding CpuUsage}"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="7">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="RAM" Classes="metric-title"/>
                            <TextBlock Grid.Column="1" Text="{Binding RamUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                        </Grid>
                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding RamUsage}"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="7">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="18">
                            <TextBlock Text="GPU" Classes="metric-title"/>
                            <TextBlock Grid.Column="1" Text="{Binding GpuUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                            <TextBlock Grid.Column="2" Text="{Binding GpuTemperatureDisplayCompactText}" Classes="muted" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding GpuUsage}"/>
                    </Grid>

                    <Grid Grid.Row="3"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="7">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DiskLabel}" Classes="metric-title"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiskUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                        </Grid>
                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding DiskUsage}"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Classes="card">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="12">
                <TextBlock Text="{x:Static res:Strings.DashboardPcSummary}"
                           Classes="section-title"/>

                <Grid Grid.Row="1"
                      RowDefinitions="*,*"
                      ColumnDefinitions="*,*"
                      RowSpacing="10"
                      ColumnSpacing="10">

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="#0D141C"
                            BorderBrush="#1E2A36"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                              RowSpacing="4">
                            <TextBlock Text="CPU"
                                       Classes="accent"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding CpuNameText}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardCores}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CpuCoresText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardThreads}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CpuThreadsText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardClock}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding CpuClockText}" FontSize="12"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="#0D141C"
                            BorderBrush="#1E2A36"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                              RowSpacing="4">
                            <TextBlock Text="{x:Static res:Strings.DashboardMemory}"
                                       Classes="accent"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding MemoryTotalText}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardSpeed}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding MemorySpeedText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardModules}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding MemoryModulesText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardChannel}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding MemoryChannelText}" FontSize="12"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Background="#0D141C"
                            BorderBrush="#1E2A36"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                              RowSpacing="4">
                            <TextBlock Text="GPU"
                                       Classes="accent"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding GpuNameText}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardVram}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding GpuVramText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardClock}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding GpuClockText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardTemp}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding PcSummaryGpuTemperatureText}" FontSize="12"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Background="#0D141C"
                            BorderBrush="#1E2A36"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                              RowSpacing="4">
                            <TextBlock Text="{x:Static res:Strings.DashboardStorage}"
                                       Classes="accent"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>

                            <TextBlock Grid.Row="1"
                                       Text="{Binding StorageNameText}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>

                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardTotal}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageTotalText}" FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <TextBlock Text="{x:Static res:Strings.DashboardUsed}" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding StorageUsedText}" FontSize="12"/>
                            </Grid>

                            <ProgressBar Grid.Row="4"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="6"
                                         Value="{Binding StorageUsedPercent}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Classes="card">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="10">
                <TextBlock Text="{Binding ThemePanelTitle}"
                           Classes="section-title"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding ThemePanelBodyText}"
                           FontFamily="Consolas, Cascadia Mono"
                           FontSize="13"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                    <TextBlock Grid.Column="0"
                               Text="{Binding ThemePanelStatusText}"
                               Classes="muted"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <Button Grid.Column="1"
                            Classes="accent-button"
                            Content="{x:Static res:Strings.GameNames}"
                            IsVisible="{Binding IsGamerThemeActive}"
                            Command="{Binding OpenGameNamesCommand}"/>

                    <Button Grid.Column="1"
                            Classes="accent-button"
                            Content="{x:Static res:Strings.ImageUpload}"
                            IsVisible="{Binding IsAnimationThemeActive}"
                            Command="{Binding OpenAnimationImageCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Classes="card">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="12">
                <TextBlock Text="{x:Static res:Strings.DashboardDisks}"
                           Classes="section-title"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding DisksText}"
                           Classes="muted"
                           FontFamily="Consolas, Cascadia Mono"
                           FontSize="12"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2"
                           Text="{x:Static res:Strings.DashboardTelemetryMoved}"
                           Classes="muted"
                           FontSize="12"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>

    <Border IsVisible="{Binding IsGameNamesDialogOpen}"
            Background="#B0070B10">
        <Border Classes="card"
                Width="460"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="16">
                <TextBlock Text="{x:Static res:Strings.GameNames}"
                           Classes="section-title"/>

                <TextBlock Grid.Row="1"
                           Text="{x:Static res:Strings.GameNamesDescription}"
                           Classes="muted"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="130,*">
                        <TextBlock Text="{x:Static res:Strings.Process}" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding GameAliasProcessText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="130,*">
                        <TextBlock Text="{x:Static res:Strings.DisplayName}" Classes="muted"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding GameAliasDisplayNameText, Mode=TwoWay}"
                                 Watermark="Resident Evil Requiem"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="130,*">
                        <TextBlock Text="{x:Static res:Strings.Source}" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding GamerSourceText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="130,*">
                        <TextBlock Text="{x:Static res:Strings.Status}" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding GameAliasStatusText}" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button Content="{x:Static res:Strings.Close}"
                            Command="{Binding CloseGameNamesCommand}"/>

                    <Button Classes="accent-button"
                            Content="{x:Static res:Strings.Delete}"
                            Command="{Binding DeleteGameAliasCommand}"/>

                    <Button Classes="accent-button"
                            Content="{x:Static res:Strings.Save}"
                            Command="{Binding SaveGameAliasCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>

    <Border IsVisible="{Binding IsAnimationImageDialogOpen}"
            Background="#B0070B10">
        <Border Classes="card"
                Width="560"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="16">
                <TextBlock Text="{x:Static res:Strings.AnimationImage}"
                           Classes="section-title"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding AnimationImageDetailsText}"
                           Classes="muted"
                           TextWrapping="Wrap"/>

                <Grid Grid.Row="2"
                      ColumnDefinitions="190,*"
                      ColumnSpacing="14">
                    <Border Width="190"
                            Height="190"
                            Background="#080E14"
                            BorderBrush="#1E2A36"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <TextBlock Text="240 x 240"
                                       Classes="muted"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !HasAnimationPreviewImage}"/>
                            <Image Source="{Binding AnimationPreviewImage}"
                                   Stretch="Uniform"
                                   IsVisible="{Binding HasAnimationPreviewImage}"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="10">
                        <Grid ColumnDefinitions="90,*">
                            <TextBlock Text="{x:Static res:Strings.File}" Classes="muted"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AnimationSelectedFileText}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="90,*">
                            <TextBlock Text="{x:Static res:Strings.Status}" Classes="muted"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AnimationImageStatusText}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Grid.Row="2"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="6">
                            <Grid ColumnDefinitions="70,*">
                                <TextBlock Text="Zoom" Classes="muted"/>
                                <Slider Grid.Column="1"
                                        Classes="animation-slider"
                                        Minimum="1"
                                        Maximum="4"
                                        TickFrequency="0.1"
                                        Value="{Binding AnimationCropZoom, Mode=TwoWay}"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="70,*">
                                <TextBlock Text="X" Classes="muted"/>
                                <Slider Grid.Column="1"
                                        Classes="animation-slider"
                                        Minimum="-1"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        Value="{Binding AnimationCropOffsetX, Mode=TwoWay}"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="70,*">
                                <TextBlock Text="Y" Classes="muted"/>
                                <Slider Grid.Column="1"
                                        Classes="animation-slider"
                                        Minimum="-1"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        Value="{Binding AnimationCropOffsetY, Mode=TwoWay}"/>
                            </Grid>

                            <Button Grid.Row="3"
                                    Content="Centralizar"
                                    HorizontalAlignment="Left"
                                    Command="{Binding CenterAnimationCropCommand}"/>
                        </Grid>

                        <Button Grid.Row="3"
                                Content="{x:Static res:Strings.ChooseImage}"
                                HorizontalAlignment="Left"
                                Command="{Binding PickAnimationImageCommand}"/>
                    </Grid>
                </Grid>

                <TextBlock Grid.Row="3"
                           Text="{x:Static res:Strings.AnimationStorageNote}"
                           Classes="muted"
                           FontSize="12"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button Content="{x:Static res:Strings.Close}"
                            Command="{Binding CloseAnimationImageCommand}"/>

                    <Button Classes="accent-button"
                            Content="{x:Static res:Strings.Upload}"
                            IsEnabled="{Binding CanUploadAnimationImage}"
                            Command="{Binding UploadAnimationImageCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
    </Grid>
</UserControl>
