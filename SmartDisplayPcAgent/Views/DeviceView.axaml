<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SmartDisplayPcAgent.Models"
             xmlns:res="using:SmartDisplayPcAgent.Resources"
             xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
             x:Class="SmartDisplayPcAgent.Views.DeviceView"
             x:DataType="vm:DeviceViewModel">

    <Grid>
        <Grid ColumnDefinitions="1*,1*"
              RowDefinitions="Auto,Auto,Auto"
              ColumnSpacing="16"
              RowSpacing="16"
              Margin="0,12,0,0">

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Classes="card">
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static res:Strings.DeviceConnection}"
                                   Classes="section-title"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.Refresh}"
                                Command="{Binding RefreshStatusCommand}"
                                Padding="10,5"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="1*,1*"
                          ColumnSpacing="26"
                          RowSpacing="7">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="7">
                        <Grid ColumnDefinitions="92,*">
                            <TextBlock Text="{x:Static res:Strings.Name}" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceName}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="92,*">
                            <TextBlock Text="{x:Static res:Strings.Mode}" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceMode}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="2" ColumnDefinitions="92,*">
                            <TextBlock Text="SSID" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceSsid}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="3" ColumnDefinitions="92,*">
                            <TextBlock Text="RSSI" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeviceRssiText}" HorizontalAlignment="Right"/>
                        </Grid>
                        </Grid>

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="92,*">
                                <TextBlock Text="{x:Static res:Strings.AgentTarget}" Classes="muted"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding State.DisplayIp, Mode=TwoWay}"
                                         Height="32"
                                         HorizontalAlignment="Stretch"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="92,*">
                                <TextBlock Text="{x:Static res:Strings.DeviceIp}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding DeviceIp}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="92,*">
                                <TextBlock Text="{x:Static res:Strings.Theme}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding DeviceThemeText}" Foreground="#FF7A1A" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="3" ColumnDefinitions="92,*">
                                <TextBlock Text="{x:Static res:Strings.PcOnline}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding PcOnlineText}" Classes="ok" HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="0.8*,1.1*,1.2*"
                          ColumnSpacing="10">

                        <Button Grid.Column="0"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.OpenServer}"
                                Command="{Binding OpenServerCommand}"
                                HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.ResetSavedWifi}"
                                Command="{Binding RequestResetWifiCommand}"
                                HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="2"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.FirmwareUpdateOta}"
                                Command="{Binding RequestFirmwareUpdateCommand}"
                                HorizontalAlignment="Stretch"/>

                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Classes="card">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <TextBlock Text="{x:Static res:Strings.DeviceLocation}"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="120,*"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="6">
                        <TextBlock Text="{x:Static res:Strings.LocationCurrent}" Classes="muted"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LocationLabelText}"
                                   HorizontalAlignment="Right"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Text="Timezone" Classes="muted"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding LocationTimezoneText}"
                                   HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Text="{x:Static res:Strings.Coordinates}" Classes="muted"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding LocationCoordinatesText}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <TextBox Grid.Column="0"
                                 Watermark="{x:Static res:Strings.LocationSearchWatermark}"
                                 Text="{Binding LocationSearchText, Mode=TwoWay}"
                                 Height="34"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.Search}"
                                Command="{Binding SearchLocationCommand}"/>
                    </Grid>

                    <ListBox Grid.Row="3"
                             Height="104"
                             IsVisible="{Binding HasLocationResults}"
                             ItemsSource="{Binding LocationResults}"
                             SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"
                             Background="#0D141C"
                             BorderBrush="#1E2A36"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceLocationOption">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="4"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <TextBlock Text="{Binding LocationStatusText}"
                                   Classes="muted"
                                   FontSize="12"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.ApplyLocation}"
                                Command="{Binding ApplyLocationCommand}"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Classes="card"
                    Padding="16,12">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <TextBlock Text="{x:Static res:Strings.DisplayTheme}"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="120,*">
                        <TextBlock Text="{x:Static res:Strings.Active}" Classes="muted"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DeviceThemeText}"
                                   Foreground="#FF7A1A"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                  Height="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ThemeOption">
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{x:Static res:Strings.ApplyTheme}"
                                Command="{Binding ApplyThemeCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ThemeApplyStatusText}"
                               Classes="muted"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="card"
                    Padding="16,12">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static res:Strings.DeviceSystem}"
                                   Classes="section-title"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="{Binding SystemDetailsButtonText}"
                                Command="{Binding ToggleSystemDetailsCommand}"
                                Padding="10,5"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="1*,1*"
                          ColumnSpacing="26">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Health}" Classes="muted"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding WeatherStatusText}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Weather}" Classes="muted"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding WeatherText}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.DashboardTemp}" Classes="muted"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TemperatureText}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Uptime}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding UptimeText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.LastReset}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding ResetReasonText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Heap}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding HeapText}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2"
                          IsVisible="{Binding IsSystemDetailsVisible}"
                          ColumnDefinitions="1*,1*"
                          ColumnSpacing="24"
                          Margin="0,4,0,0">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="8">
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Checkpoint}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastCheckpointText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.LastData}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding LastMetricsText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Marker}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding RestartIntentText}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="8">
                            <Grid ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.Advanced}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding WeatherStatusText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.MaxBlock}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding MaxFreeBlockText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="2" ColumnDefinitions="96,*">
                                <TextBlock Text="{x:Static res:Strings.DashboardMemory}" Classes="muted"/>
                                <TextBlock Grid.Column="1" Text="{Binding HeapFragmentationText}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                Spacing="8">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Classes="muted"
                                   FontSize="12"/>
                        <TextBlock Text="·"
                                   Classes="muted"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding LastRefreshText}"
                                   Classes="muted"
                                   FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Classes="card"
                    Padding="16,10">
                <Grid ColumnDefinitions="150,*,Auto"
                      ColumnSpacing="18">
                    <TextBlock Text="{x:Static res:Strings.Telemetry}"
                               Classes="section-title"
                               VerticalAlignment="Center"/>

                    <Grid Grid.Column="1"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="18"
                          VerticalAlignment="Center">
                        <CheckBox Content="{x:Static res:Strings.SendTelemetryToDisplay}"
                                  IsChecked="{Binding State.SendToDisplayEnabled}"
                                  VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding TelemetryDetailText}"
                                   Classes="muted"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Column="2"
                          RowDefinitions="Auto"
                          VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="14"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{Binding State.LastPostText}"
                                       VerticalAlignment="Center"
                                       Classes="ok"
                                       FontWeight="SemiBold"/>

                            <Button Classes="accent-button"
                                    Content="{x:Static res:Strings.SendTest}"
                                    Command="{Binding SendTestCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border IsVisible="{Binding IsLocationPreviewDialogOpen}"
                Background="#B0070B10">
            <Border Classes="card"
                    Width="500"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="14">
                    <TextBlock Text="{x:Static res:Strings.LocationPreviewTitle}"
                               Classes="section-title"/>

                    <TextBlock Grid.Row="1"
                               Text="{x:Static res:Strings.LocationPreviewMessage}"
                               Classes="muted"
                               TextWrapping="Wrap"/>

                    <TextBox Grid.Row="2"
                             Text="{Binding LocationPreviewPayload}"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             MinHeight="150"
                             FontFamily="Consolas, Cascadia Mono"
                             FontSize="13"/>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Classes="accent-button"
                                Content="{x:Static res:Strings.Close}"
                                Command="{Binding CloseLocationPreviewDialogCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border IsVisible="{Binding IsConfirmDialogOpen}"
                Background="#B0070B10">
            <Border Classes="card"
                    Width="420"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="16">
                    <TextBlock Text="{Binding ConfirmDialogTitle}"
                               Classes="section-title"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding ConfirmDialogMessage}"
                               Classes="muted"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <Button Content="{x:Static res:Strings.Cancel}"
                                Command="{Binding CancelConfirmDialogCommand}"/>

                        <Button Classes="accent-button"
                                Content="{Binding ConfirmDialogActionText}"
                                Command="{Binding ConfirmDialogCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
