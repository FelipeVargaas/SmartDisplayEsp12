<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="using:SmartDisplayPcAgent.Resources"
        xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
        xmlns:views="using:SmartDisplayPcAgent.Views"
        x:Class="SmartDisplayPcAgent.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100"
        Height="750"
        MinWidth="900"
        MinHeight="620"
        Title="TinyDash Agent"
        Background="#070B10">


    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#8FA3B8"/>
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style Selector="TextBlock.metric-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.metric-value">
            <Setter Property="Foreground" Value="#FF7A1A"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.accent">
            <Setter Property="Foreground" Value="#D46F2A"/>
        </Style>

        <Style Selector="TextBlock.ok">
            <Setter Property="Foreground" Value="#35C46B"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#101820"/>
            <Setter Property="BorderBrush" Value="#1E2A36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Foreground" Value="#FF7A1A"/>
            <Setter Property="Background" Value="#1E2A36"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>



        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Foreground" Value="#FF8A2A"/>
            <Setter Property="BorderBrush" Value="#FF8A2A"/>
            <Setter Property="Background" Value="#121C25"/>
        </Style>

        <Style Selector="Button.accent-button">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="BorderBrush" Value="#D46F2A"/>
        </Style>

        <Style Selector="Button.nav-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8FA3B8"/>
            <Setter Property="FontSize" Value="23"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style Selector="Button.nav-tab:pointerover">
            <Setter Property="Foreground" Value="#FF8A2A"/>
            <Setter Property="Background" Value="#0A1017"/>
        </Style>

        <Style Selector="Button.nav-tab.active">
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#FF7A1A"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#FF7A1A"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="22"
          RowSpacing="14">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="18">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="18">
                <Border Width="4"
                        Height="48"
                        CornerRadius="2"
                        Background="#D46F2A"/>

                <StackPanel Spacing="2"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="TinyDash"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Agent"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#D46F2A"/>
                    </StackPanel>

                    <TextBlock Text="{x:Static res:Strings.AppSubtitle}"
                               FontSize="14"
                               Classes="muted"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Classes="nav-tab"
                        Classes.active="{Binding IsDashboardSelected}"
                        Content="{x:Static res:Strings.NavDashboard}"
                        Command="{Binding SelectDashboardCommand}"/>

                <Button Classes="nav-tab"
                        Classes.active="{Binding IsDeviceSelected}"
                        Content="{x:Static res:Strings.NavDevice}"
                        Command="{Binding SelectDeviceCommand}"/>
            </StackPanel>

            <Border Grid.Column="2"
                    Classes="card"
                    Padding="16,10"
                    MinWidth="260"
                    HorizontalAlignment="Right">
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8">
                    <Ellipse Grid.Row="0"
                             Grid.Column="0"
                             Width="9"
                             Height="9"
                             Fill="#35C46B"
                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding Dashboard.EspHeaderStatusText}"
                               Classes="ok"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Dashboard.DeviceHeaderText}"
                               Classes="muted"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding IsDashboardSelected}">
                <views:DashboardView DataContext="{Binding Dashboard}"/>
            </Grid>

            <Grid IsVisible="{Binding IsDeviceSelected}">
                <views:DeviceView DataContext="{Binding Device}"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="18"
              MinHeight="28">
            <TextBlock Grid.Column="0"
                       Text="{Binding Dashboard.StatusText}"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="{x:Static res:Strings.SendInterval}"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="{x:Static res:Strings.LanguageLabel}"
                           Classes="muted"
                           VerticalAlignment="Center"/>

                <ComboBox Width="145"
                          Height="30"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:LanguageOption">
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding LanguageRestartText}"
                           Classes="accent"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <TextBlock Text="{x:Static res:Strings.Version}"
                           Classes="muted"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
