<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
             x:Class="SmartDisplayPcAgent.Views.DeviceView"
             x:DataType="vm:DeviceViewModel">

    <Grid ColumnDefinitions="1*,1*"
          RowDefinitions="*,Auto"
          ColumnSpacing="16"
          RowSpacing="16"
          Margin="0,12,0,0">

        <Border Grid.Row="0"
                Grid.Column="0"
                Classes="card">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="14">
                <TextBlock Text="CONNECTION"
                           Classes="section-title"/>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Text="Name" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceName}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="120,*">
                        <TextBlock Text="Mode" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceMode}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="120,*">
                        <TextBlock Text="Agent target" Classes="muted"/>
                        <TextBox Grid.Column="1" Text="{Binding State.DisplayIp, Mode=TwoWay}" Height="34"/>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="120,*">
                        <TextBlock Text="Device IP" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceIp}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="4" ColumnDefinitions="120,*">
                        <TextBlock Text="SSID" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceSsid}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="120,*">
                        <TextBlock Text="RSSI" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceRssiText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="6" ColumnDefinitions="120,*">
                        <TextBlock Text="Theme" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding DeviceThemeText}" Foreground="#168BFF" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="7" ColumnDefinitions="120,*">
                        <TextBlock Text="PC Online" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding PcOnlineText}" Classes="ok" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>

                <Button Grid.Row="2"
                        Classes="accent-button"
                        Content="Refresh"
                        Command="{Binding RefreshStatusCommand}"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Classes="card">
            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="14">
                <TextBlock Text="SYSTEM"
                           Classes="section-title"/>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="120,*">
                        <TextBlock Text="Uptime" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding UptimeText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="120,*">
                        <TextBlock Text="Last reset" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding ResetReasonText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="120,*">
                        <TextBlock Text="Reset detail" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding ResetInfoText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="120,*">
                        <TextBlock Text="Marker" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding RestartIntentText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="4" ColumnDefinitions="120,*">
                        <TextBlock Text="Checkpoint" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastCheckpointText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="120,*">
                        <TextBlock Text="Heap" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding HeapText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="6" ColumnDefinitions="120,*">
                        <TextBlock Text="Frag" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding HeapFragmentationText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="7" ColumnDefinitions="120,*">
                        <TextBlock Text="Max block" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding MaxFreeBlockText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="8" ColumnDefinitions="120,*">
                        <TextBlock Text="Flash" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding FlashText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="9" ColumnDefinitions="120,*">
                        <TextBlock Text="Weather" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding WeatherText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="10" ColumnDefinitions="120,*">
                        <TextBlock Text="Temp" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding TemperatureText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="11" ColumnDefinitions="120,*">
                        <TextBlock Text="Weather status" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding WeatherStatusText}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Row="12" ColumnDefinitions="120,*">
                        <TextBlock Text="Last data" Classes="muted"/>
                        <TextBlock Grid.Column="1" Text="{Binding LastMetricsText}" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="8">
                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="muted"
                               FontSize="12"/>
                    <TextBlock Text="·"
                               Classes="muted"
                               FontSize="12"/>
                    <TextBlock Text="{Binding LastRefreshText}"
                               Classes="muted"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Classes="card"
                Padding="16,12">
            <Grid ColumnDefinitions="1*,1*"
                  ColumnSpacing="28">
                <Grid Grid.Column="0"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="8">
                    <TextBlock Text="DISPLAY THEME"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="120,*">
                        <TextBlock Text="Active" Classes="muted"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DeviceThemeText}"
                                   Foreground="#168BFF"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                  Height="36">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ThemeOption">
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="Apply Theme"
                                Command="{Binding ApplyThemeCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ThemeApplyStatusText}"
                               Classes="muted"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>

                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="8">
                    <TextBlock Text="TELEMETRY"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Grid.Column="0"
                                    Spacing="6">
                            <CheckBox Content="Send telemetry to display"
                                      IsChecked="{Binding State.SendToDisplayEnabled}"/>

                            <TextBlock Text="{Binding State.DisplayStatusText}"
                                       Classes="muted"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="8"
                                    VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding State.LastPostText}"
                                       HorizontalAlignment="Right"
                                       Classes="ok"
                                       FontWeight="SemiBold"/>

                            <Button Classes="accent-button"
                                    Content="Send Test"
                                    Command="{Binding SendTestCommand}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="Target IP is configured in Connection."
                               Classes="muted"
                               FontSize="12"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
