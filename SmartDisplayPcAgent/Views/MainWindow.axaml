<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartDisplayPcAgent.ViewModels"
        x:Class="SmartDisplayPcAgent.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="920"
        Height="600"
        MinWidth="860"
        MinHeight="650"
        Title="TinyDash Agent"
        Background="#070B10">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI"/>
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#8FA3B8"/>
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style Selector="TextBlock.metric-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.metric-value">
            <Setter Property="Foreground" Value="#168BFF"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.accent">
            <Setter Property="Foreground" Value="#D46F2A"/>
        </Style>

        <Style Selector="TextBlock.ok">
            <Setter Property="Foreground" Value="#35C46B"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="#101820"/>
            <Setter Property="BorderBrush" Value="#1E2A36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Foreground" Value="#168BFF"/>
            <Setter Property="Background" Value="#1E2A36"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background" Value="#0D141C"/>
            <Setter Property="Foreground" Value="#F2F6FA"/>
            <Setter Property="BorderBrush" Value="#304154"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.accent-button">
            <Setter Property="Foreground" Value="#D46F2A"/>
            <Setter Property="BorderBrush" Value="#D46F2A"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="22"
          RowSpacing="16">

        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="18">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="18">
                <Border Width="4"
                        Height="48"
                        CornerRadius="2"
                        Background="#D46F2A"/>

                <StackPanel Spacing="2"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="TinyDash"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Agent"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#D46F2A"/>
                    </StackPanel>

                    <TextBlock Text="Display telemetry service"
                               FontSize="14"
                               Classes="muted"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1"
                    Classes="card"
                    Padding="16,10"
                    MinWidth="250">
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8">
                    <Ellipse Grid.Row="0"
                             Grid.Column="0"
                             Width="9"
                             Height="9"
                             Fill="#35C46B"
                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="{Binding EspHeaderStatusText}"
                               Classes="ok"
                               FontSize="15"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding DisplayIp}"
                               Classes="muted"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="1.05*,1*"
              RowDefinitions="1.15*,0.85*"
              ColumnSpacing="16"
              RowSpacing="16">

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Classes="card">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="14">
                    <TextBlock Text="LOCAL METRICS"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          RowDefinitions="*,*,*,*"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="CPU" Classes="metric-title"/>
                                <TextBlock Grid.Column="1" Text="{Binding CpuUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding CpuUsage}"/>
                        </Grid>

                        <Grid Grid.Row="1"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="RAM" Classes="metric-title"/>
                                <TextBlock Grid.Column="1" Text="{Binding RamUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding RamUsage}"/>
                        </Grid>

                        <Grid Grid.Row="2"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="18">
                                <TextBlock Text="GPU" Classes="metric-title"/>
                                <TextBlock Grid.Column="1" Text="{Binding GpuUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                                <TextBlock Grid.Column="2" Text="{Binding GpuTemperatureDisplayCompactText}" Classes="accent" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding GpuUsage}"/>
                        </Grid>

                        <Grid Grid.Row="3"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="7">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding DiskLabel}" Classes="metric-title"/>
                                <TextBlock Grid.Column="1" Text="{Binding DiskUsage, StringFormat='{}{0:0}%'}" Classes="metric-value"/>
                            </Grid>
                            <ProgressBar Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding DiskUsage}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Classes="card">
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="14">
                    <TextBlock Text="DISPLAY CONNECTION"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="9">
                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Text="Device" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="ESP8266" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="120,*">
                            <TextBlock Text="IP" Classes="muted"/>
                            <TextBox Grid.Column="1" Text="{Binding DisplayIp, Mode=TwoWay}" Height="34"/>
                        </Grid>

                        <Grid Grid.Row="2" ColumnDefinitions="120,*">
                            <TextBlock Text="Status" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayStatusShortText}" Classes="ok" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="3" ColumnDefinitions="120,*">
                            <TextBlock Text="Mode" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveThemeText}" Foreground="#168BFF" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="4" ColumnDefinitions="120,*">
                            <TextBlock Text="Last POST" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding LastPostText}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  Content="Send telemetry to display"
                                  IsChecked="{Binding SendToDisplayEnabled}"
                                  VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Classes="accent-button"
                                Content="Send Test"
                                Command="{Binding SendTestCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Classes="card">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock Text="GAMER HUD"
                               Classes="section-title"/>

                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="9">
                        <Grid ColumnDefinitions="110,*">
                            <TextBlock Text="Game" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding GamerGameValueText}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="110,*,110,*">
                            <TextBlock Text="FPS" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding GamerFpsValueText}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Frametime" Classes="muted" Margin="20,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="{Binding GamerFrametimeValueText}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="2" ColumnDefinitions="110,*">
                            <TextBlock Text="GPU Temp" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding GpuTemperatureDisplayCompactText}" Classes="accent" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="3" ColumnDefinitions="110,*">
                            <TextBlock Text="Source" Classes="muted"/>
                            <TextBlock Grid.Column="1" Text="{Binding GamerSourceValueText}" Classes="accent" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="card">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock Text="DISKS"
                               Classes="section-title"/>

                    <TextBlock Grid.Row="1"
                               Text="{Binding DisksText}"
                               Classes="muted"
                               FontFamily="Consolas, Cascadia Mono"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,*"
              MinHeight="32">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="Send interval: 1.0 s"
                       Classes="muted"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="Version: 1.0.0"
                       Classes="muted"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
